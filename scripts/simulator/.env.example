# Supabase Configuration for Simulator
# Copy this file to .env in the project root and fill in your values

# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (found in Supabase Dashboard > Settings > API)
# WARNING: This key bypasses Row Level Security - keep it secret!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
