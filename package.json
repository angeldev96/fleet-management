{
  "name": "material-dashboard-pro-react",
  "version": "1.10.0",
  "private": true,
  "dependencies": {
    "@material-ui/core": "4.11.4",
    "@material-ui/icons": "4.11.2",
    "@supabase/supabase-js": "^1.35.7",
    "classnames": "2.3.1",
    "dotenv": "^16.6.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.0.0",
    "mapbox-gl": "^2.15.0",
    "perfect-scrollbar": "1.5.1",
    "react": "17.0.2",
    "react-bootstrap-sweetalert": "5.2.0",
    "react-dom": "17.0.2",
    "react-router-dom": "5.2.0",
    "react-scripts": "4.0.3",
    "sass": "1.45.0"
  },
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider ESLINT_NO_DEV_ERRORS=true react-scripts start",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts build && gulp licenses",
    "test": "react-scripts test --env=jsdom",
    "eject": "react-scripts eject",
    "deploy": "npm run build",
    "lint:check": "eslint . --ext=js,jsx --max-warnings=999",
    "lint:fix": "eslint . --ext=js,jsx --fix --max-warnings=999",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,scss,md}\"",
    "install:clean": "rm -rf node_modules/ && rm -rf package-lock.json && npm install && npm start",
    "compile-sass": "sass src/assets/scss/material-dashboard-pro-react.scss src/assets/css/material-dashboard-pro-react.css",
    "minify-sass": "sass src/assets/scss/material-dashboard-pro-react.scss src/assets/css/material-dashboard-pro-react.min.css --style compressed",
    "map-sass": "sass src/assets/scss/material-dashboard-pro-react.scss src/assets/css/material-dashboard-pro-react.css --source-map",
    "simulator": "node scripts/simulator/index.js",
    "simulator:start": "node scripts/simulator/index.js"
  },
  "optionalDependencies": {
    "@babel/core": "7.14.0",
    "typescript": "4.2.4"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "8.3.0",
    "eslint-plugin-prettier": "3.4.0",
    "gulp": "4.0.2",
    "gulp-append-prepend": "1.0.9",
    "prettier": "2.2.1",
    "react-refresh": "^0.10.0"
  },
  "overrides": {
    "fsevents": "^2.3.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": []
  }
}
